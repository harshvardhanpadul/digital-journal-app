<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>

    <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet">
</head>
<body>

<div class="container mt-5">

    <h1 class="mb-4">Your Journal</h1>

    <a href="/new" class="btn btn-primary mb-3">
        New Entry
    </a>

    <a href="/logout" class="btn btn-danger mb-3">
        Logout
    </a>

    <% entries.forEach(entry => { %>

    <div class="card mb-3">

        <div class="card-body">

            <h3>
                <%= entry.title %>
            </h3>

            <p>
                <%= entry.content %>
            </p>

            <a
            href="/edit/<%= entry.id %>"
            class="btn btn-warning">
                Edit
            </a>

            <a
            href="/delete/<%= entry.id %>"
            class="btn btn-danger">
                Delete
            </a>

        </div>

    </div>

    <% }) %>

</div>

</body>
</html>